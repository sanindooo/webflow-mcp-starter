# Your Webflow site URL (used by Playwright for visual testing)
WEBFLOW_SITE_URL=https://your-site.webflow.io

# Figma Personal Access Token (expires every 90 days)
# Required scope: file_content:read
# Generate at: https://www.figma.com/developers/api#access-tokens
FIGMA_API_TOKEN=

# Webflow API Token (site-level or workspace-level)
# Generate at: https://webflow.com/dashboard/sites/{site-name}integrations
WEBFLOW_API_TOKEN=

# Webflow Site ID (found in Site Settings > General > Site ID)
WEBFLOW_SITE_ID=
